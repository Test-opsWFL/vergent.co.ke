---
import site from '../data/site.json';

interface Props {
  title?: string;
  showSupport?: boolean;
}

const { title = 'Where we are', showSupport = true } = Astro.props;
---

<div>
  <p class="eyebrow">{title}</p>
  <ul class="mt-4 grid gap-px overflow-hidden rounded-lg border border-border bg-border md:grid-cols-3">
    {site.offices.map((o) => (
      <li class="bg-card p-6">
        <p class="font-display text-h3 text-ink">{o.city}</p>
        <p class="mt-1 text-sm text-muted">{o.country}</p>
      </li>
    ))}
  </ul>
  {showSupport && (
    <p class="mt-3 text-xs text-muted">
      Round-the-clock support extends to {site.supportPresence.join(' and ')}.
    </p>
  )}
</div>
