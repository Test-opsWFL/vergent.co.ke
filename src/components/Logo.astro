---
interface Props {
  variant?: 'horizontal' | 'mark-only' | 'stacked' | 'full';
  size?: 'sm' | 'md' | 'lg';
}

const { variant = 'full', size = 'md' } = Astro.props;

const fullSize = {
  sm: 'h-8',
  md: 'h-12',
  lg: 'h-20',
}[size];

const markSize = {
  sm: 'h-7 w-7',
  md: 'h-10 w-10',
  lg: 'h-16 w-16',
}[size];

const horizontalMarkSize = {
  sm: 'h-7 w-7',
  md: 'h-9 w-9',
  lg: 'h-12 w-12',
}[size];

const horizontalWordSize = {
  sm: 'text-base',
  md: 'text-xl',
  lg: 'text-3xl',
}[size];
---

{variant === 'mark-only' ? (
  <img
    src="/logos/vergent-mark.png"
    alt="Vergent"
    class:list={[markSize, 'object-contain']}
  />
) : variant === 'full' || variant === 'stacked' ? (
  <span class:list={[fullSize, 'inline-flex w-auto']}>
    <img
      src="/logos/vergent-logo.png"
      alt="Vergent Technology Solutions"
      class:list={[fullSize, 'logo-light w-auto object-contain']}
    />
    <img
      src="/logos/vergent-logo-dark.png"
      alt="Vergent Technology Solutions"
      class:list={[fullSize, 'logo-dark w-auto object-contain']}
    />
  </span>
) : (
  <span class="inline-flex items-center gap-3">
    <img src="/logos/vergent-mark.png" alt="" class:list={[horizontalMarkSize, 'flex-shrink-0 object-contain']} />
    <span class="inline-flex flex-col leading-none">
      <span class:list={['font-display font-extrabold tracking-tight text-ink', horizontalWordSize]}>
        Vergent
      </span>
      <span class="mt-1 font-display text-[9px] font-semibold uppercase tracking-[0.18em] text-accent">
        Technology Solutions
      </span>
    </span>
  </span>
)}
