---
import site from '../data/site.json';
const stats = site.stats ?? [];
---

{stats.length > 0 && (
  <section class="border-y border-border bg-card">
    <div class="container-wide grid gap-6 py-7 md:grid-cols-4">
      {stats.map((s) => (
        <div class="flex flex-col">
          <p
            class="font-display text-3xl font-extrabold tracking-tight text-ink md:text-4xl"
            data-counter={s.value}
          >
            {s.value}
          </p>
          <p class="mt-1 text-sm leading-snug text-muted">{s.label}</p>
        </div>
      ))}
    </div>
  </section>
)}
