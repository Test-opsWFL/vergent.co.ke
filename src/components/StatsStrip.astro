---
import site from '../data/site.json';
const capabilities = site.capabilities ?? [];
---

{capabilities.length > 0 && (
  <section class="border-y border-border bg-card">
    <div class="container-wide grid gap-px overflow-hidden bg-border md:grid-cols-4">
      {capabilities.map((c) => (
        <div class="bg-card p-6 md:p-7">
          <p class="font-display text-sm font-semibold text-ink">{c.title}</p>
          <p class="mt-1 text-sm leading-snug text-muted">{c.summary}</p>
          {c.items && c.items.length > 0 && (
            <ul class="mt-3 space-y-1">
              {c.items.map((item) => (
                <li class="flex items-start gap-2 text-xs text-muted">
                  <span aria-hidden="true" class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>
)}
