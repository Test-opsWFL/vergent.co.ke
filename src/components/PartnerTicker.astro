---
import site from '../data/site.json';

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
}

const {
  eyebrow = 'Partnerships',
  title = 'Built on the platforms enterprises already trust.',
  subtitle = 'We deliver against the full weight of Microsoft, Oracle, SAP, AWS, and a curated ecosystem of specialist vendors.',
} = Astro.props;

// Repeat list once for a seamless infinite marquee.
const track = [...site.partners, ...site.partners];
---

<section class="container-wide py-section">
  <div class="max-w-2xl">
    <p class="eyebrow">{eyebrow}</p>
    <h2 class="mt-2 text-h2 font-display font-semibold">{title}</h2>
    <p class="mt-3 text-sm leading-6 text-muted md:text-base">{subtitle}</p>
  </div>
</section>

<div class="ticker overflow-hidden border-y border-border bg-card py-5">
  <ul
    class="ticker-track flex items-center gap-12"
    role="list"
    aria-label="Technology partners"
  >
    {track.map((p, i) => (
      <li class="flex items-center" aria-hidden={i >= site.partners.length ? 'true' : undefined}>
        <span
          class="font-display text-base md:text-lg font-extrabold tracking-tight text-muted/80 hover:text-ink transition-colors whitespace-nowrap"
          style={p.color ? `color:${p.color};` : undefined}
        >
          {p.name}
        </span>
      </li>
    ))}
  </ul>
</div>
