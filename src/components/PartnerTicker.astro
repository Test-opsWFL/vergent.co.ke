---
import site from '../data/site.json';

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
}

const {
  eyebrow = 'Partners & specialisms',
  title = 'Partnered with vendors. Fluent in the platforms enterprises run.',
  subtitle = 'A small bench of strategic partners we deliver alongside, plus deep specialisation in the cloud and ERP platforms our clients already rely on.',
} = Astro.props;

const partners = site.partners ?? [];
const specialisms = site.specialisms ?? [];
const ticker = [...specialisms, ...specialisms];
---

<section class="container-wide py-section">
  <div class="max-w-2xl">
    <p class="eyebrow">{eyebrow}</p>
    <h2 class="mt-2 text-h2 font-display font-semibold">{title}</h2>
    <p class="mt-3 text-sm leading-6 text-muted md:text-base">{subtitle}</p>
  </div>

  {partners.length > 0 && (
    <div class="mt-10">
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted">Strategic partners</p>
      <ul class="mt-4 grid grid-cols-2 gap-px overflow-hidden rounded-lg border border-border bg-border sm:grid-cols-4">
        {partners.map((p) => (
          <li class="bg-card p-6 flex items-center justify-center">
            <a
              href={p.url}
              target="_blank"
              rel="noopener"
              aria-label={p.name}
              class="block opacity-80 grayscale transition hover:opacity-100 hover:grayscale-0"
            >
              <img src={p.logo} alt={p.name} class="partner-logo h-8 w-auto max-w-[140px] object-contain" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}
</section>

{specialisms.length > 0 && (
  <div class="ticker overflow-hidden border-y border-border bg-card py-5">
    <ul class="ticker-track flex items-center gap-12" role="list" aria-label="Technology specialisms">
      {ticker.map((p, i) => (
        <li class="flex items-center" aria-hidden={i >= specialisms.length ? 'true' : undefined}>
          <span class="font-display text-base md:text-lg font-extrabold tracking-tight text-muted/80 hover:text-ink transition-colors whitespace-nowrap">
            {p.name}
          </span>
        </li>
      ))}
    </ul>
  </div>
)}
