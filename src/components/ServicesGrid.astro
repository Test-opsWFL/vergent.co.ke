---
import { getCollection } from 'astro:content';

interface Props {
  variant?: 'compact' | 'full';
  showHeader?: boolean;
}

const { variant = 'full', showHeader = true } = Astro.props;

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const groupLabels: Record<string, string> = {
  'cloud-modernization': 'Cloud & modernization',
  'security-compliance': 'Security & compliance',
  'software-data':       'Software & data',
};
---

<section class="container-content py-section md:py-section-lg">
  {showHeader && (
    <div class="max-w-2xl">
      <p class="eyebrow">Services</p>
      <h2 class="mt-3 text-h2 font-display font-semibold">
        Three practices, one delivery model.
      </h2>
      <p class="mt-4 text-base text-muted">
        Cloud and modernization, security and compliance, software and data. Engagements run from short architecture reviews to multi-year transformations — same senior team either way.
      </p>
    </div>
  )}

  <div class:list={[
    'mt-12 grid gap-px overflow-hidden rounded-lg border border-border bg-border',
    variant === 'compact' ? 'md:grid-cols-3' : 'md:grid-cols-3',
  ]}>
    {services.map((service) => (
      <article class="bg-card p-8 md:p-10">
        <p class="eyebrow">{groupLabels[service.data.group] ?? service.data.group}</p>
        <h3 class="mt-3 text-lg font-display font-semibold text-ink">{service.data.title}</h3>
        <p class="mt-3 text-sm leading-6 text-muted">{service.data.summary}</p>
        {variant === 'full' && service.data.bullets.length > 0 && (
          <ul class="mt-5 space-y-2 text-sm text-ink">
            {service.data.bullets.map((b) => (
              <li class="flex gap-3">
                <span aria-hidden="true" class="mt-2 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        )}
      </article>
    ))}
  </div>
</section>
