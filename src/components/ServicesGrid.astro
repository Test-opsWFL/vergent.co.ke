---
import { getCollection } from 'astro:content';
import ServiceIcon from './ServiceIcon.astro';

interface Props {
  variant?: 'compact' | 'full';
  showHeader?: boolean;
  wideContainer?: boolean;
}

const { variant = 'full', showHeader = true, wideContainer = true } = Astro.props;

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const groupLabels: Record<string, string> = {
  'cloud-modernization': 'Cloud & modernization',
  'security-compliance': 'Security & compliance',
  'software-data':       'Software & data',
};

const containerClass = wideContainer ? 'container-wide' : 'container-content';
---

<section class:list={[containerClass, 'py-section']}>
  {showHeader && (
    <div class="max-w-2xl">
      <p class="eyebrow">Services</p>
      <h2 class="mt-3 text-h2 font-display font-semibold">
        Three practices, one delivery model.
      </h2>
      <p class="mt-4 text-base text-muted">
        Cloud and modernization, security and compliance, software and data. Engagements run from short architecture reviews to multi-year transformations — same senior team either way.
      </p>
    </div>
  )}

  <div class="mt-8 grid gap-px overflow-hidden rounded-lg border border-border bg-border md:grid-cols-3">
    {services.map((service) => (
      <article class="bg-card p-6 md:p-7 flex flex-col">
        <div class="flex items-center gap-3">
          {service.data.icon && (
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent-soft text-accent">
              <ServiceIcon name={service.data.icon} class="h-5 w-5" />
            </span>
          )}
          <p class="eyebrow">{groupLabels[service.data.group] ?? service.data.group}</p>
        </div>

        <h3 class="mt-4 text-base font-display font-semibold text-ink">{service.data.title}</h3>

        {service.data.tagline && (
          <p class="mt-1.5 text-sm leading-snug text-ink/85">{service.data.tagline}</p>
        )}

        <p class="mt-1.5 text-sm leading-6 text-muted">{service.data.summary}</p>

        {variant === 'full' && service.data.bullets.length > 0 && (
          <>
            <p class="mt-4 text-[10px] font-semibold uppercase tracking-[0.14em] text-muted">Capabilities</p>
            <ul class="mt-2 space-y-1.5 text-sm text-ink">
              {service.data.bullets.map((b) => (
                <li class="flex gap-3">
                  <span aria-hidden="true" class="mt-2 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </>
        )}

        {variant === 'full' && service.data.outcomes.length > 0 && (
          <>
            <p class="mt-4 text-[10px] font-semibold uppercase tracking-[0.14em] text-muted">What you'll see</p>
            <ul class="mt-2 space-y-1.5 text-sm text-ink/90">
              {service.data.outcomes.map((o) => (
                <li class="flex gap-3">
                  <svg aria-hidden="true" class="mt-1 h-3.5 w-3.5 flex-shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12l5 5L20 7"/>
                  </svg>
                  <span>{o}</span>
                </li>
              ))}
            </ul>
          </>
        )}
      </article>
    ))}
  </div>
</section>
