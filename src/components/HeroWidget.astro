---
// Hero visual: a wireframe of "the digital landscape" — what Vergent
// actually architects. Layered system stack with security as a cross-cutting
// rail. No repeated copy from the rest of the page.

const layers = [
  {
    code: 'L04',
    title: 'Agents & experiences',
    items: ['Co-pilots', 'Workflows', 'Portals', 'Mobile'],
    accent: true,
  },
  {
    code: 'L03',
    title: 'Applications',
    items: ['ERP', 'CRM', 'Custom builds', 'APIs'],
  },
  {
    code: 'L02',
    title: 'Data & platform',
    items: ['Warehouses', 'Streams', 'Identity', 'Integration'],
  },
  {
    code: 'L01',
    title: 'Infrastructure',
    items: ['Cloud', 'Network', 'Compute', 'Storage'],
  },
];
---

<div class="relative">
  <!-- Soft glow -->
  <div aria-hidden="true" class="absolute -inset-6 -z-10 rounded-3xl bg-gradient-to-br from-accent/10 via-brand-blue/10 to-transparent blur-2xl"></div>

  <div class="rounded-xl bg-card shadow-mockup ring-1 ring-border overflow-hidden">
    <!-- Blueprint title bar -->
    <div class="flex items-center justify-between gap-3 border-b border-border bg-surface/60 px-4 py-2.5">
      <div class="flex items-center gap-2">
        <svg aria-hidden="true" class="h-3.5 w-3.5 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 5h18M3 12h18M3 19h18M7 5v14M17 5v14"/>
        </svg>
        <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-muted">
          Reference architecture
        </span>
      </div>
      <span class="font-mono text-[10px] text-muted">REV · DLT-01</span>
    </div>

    <!-- Diagram body -->
    <div class="p-5 md:p-6">
      <div class="grid grid-cols-[1fr,auto] gap-3">
        <!-- Layered stack -->
        <ul class="space-y-2" role="list">
          {layers.map((l) => (
            <li class:list={[
              'rounded-md border p-3',
              l.accent
                ? 'border-accent/40 bg-accent/[0.04]'
                : 'border-border border-dashed bg-surface/40',
            ]}>
              <div class="flex items-baseline justify-between gap-3">
                <span class:list={[
                  'font-mono text-[10px] uppercase tracking-[0.16em]',
                  l.accent ? 'text-accent' : 'text-muted',
                ]}>{l.code}</span>
                <span class="font-display text-xs font-semibold text-ink">{l.title}</span>
              </div>
              <div class="mt-2 grid grid-cols-4 gap-1.5">
                {l.items.map((item) => (
                  <span class="truncate rounded border border-border bg-card px-1.5 py-1 text-center text-[9px] font-medium text-muted">
                    {item}
                  </span>
                ))}
              </div>
            </li>
          ))}
        </ul>

        <!-- Cross-cutting security rail -->
        <div class="flex">
          <div class="flex w-9 flex-col items-center justify-between rounded-md border border-dashed border-accent/40 bg-accent/[0.04] py-3">
            <svg aria-hidden="true" class="h-3.5 w-3.5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3 4 6v6c0 5 3.5 8.5 8 9 4.5-.5 8-4 8-9V6l-8-3Z"/>
            </svg>
            <span
              class="font-mono text-[9px] uppercase tracking-[0.2em] text-accent"
              style="writing-mode: vertical-rl; transform: rotate(180deg);"
            >
              Security & compliance
            </span>
            <span class="font-mono text-[9px] text-accent/60">▲</span>
          </div>
        </div>
      </div>

      <!-- Caption -->
      <p class="mt-5 border-t border-border pt-4 text-xs leading-5 text-muted">
        <span class="font-display font-semibold text-ink">Architecting the digital landscape.</span>
        Four layers, one stack — designed, built, and operated by the same senior team.
      </p>
    </div>

    <!-- Footer -->
    <div class="flex items-center justify-between gap-2 border-t border-border bg-surface/60 px-5 py-3 text-[11px] text-muted">
      <span class="inline-flex items-center gap-1.5">
        <img src="/logos/vergent-mark.png" alt="" class="h-4 w-4 object-contain" />
        <span class="font-display font-semibold text-ink">Vergent</span>
      </span>
      <span class="font-mono text-[10px] uppercase tracking-[0.14em]">
        Cloud · Data · Apps · Agents
      </span>
    </div>
  </div>

  <!-- Floating chip -->
  <div class="absolute -bottom-4 -left-4 hidden md:block">
    <div class="rounded-md bg-brand-navy px-3 py-2 text-xs font-medium text-white shadow-mockup">
      <span class="text-accent">Architects</span> of the modern enterprise stack
    </div>
  </div>
</div>
