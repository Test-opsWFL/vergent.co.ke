---
import contact from '../data/pages/contact.json';

const WEB3FORMS_KEY = 'YOUR_WEB3FORMS_KEY';
---

<form
  id="contact-form"
  action="https://api.web3forms.com/submit"
  method="POST"
  class="space-y-6"
  novalidate
>
  <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
  <input type="hidden" name="subject" value="New enquiry from vergent.co.ke" />
  <input type="hidden" name="from_name" value="Vergent website" />
  <input type="hidden" name="redirect" value="false" />

  <!-- Honeypot -->
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

  <div class="grid gap-6 md:grid-cols-2">
    <label class="block">
      <span class="text-sm font-medium text-ink">Name</span>
      <input
        type="text"
        name="name"
        required
        autocomplete="name"
        class="mt-2 block w-full rounded-lg border border-border bg-card px-3 py-2.5 text-sm text-ink placeholder:text-muted focus:border-ink/40 focus:outline-none focus:ring-2 focus:ring-accent/30"
        placeholder="Jane Mwangi"
      />
    </label>

    <label class="block">
      <span class="text-sm font-medium text-ink">Work email</span>
      <input
        type="email"
        name="email"
        required
        autocomplete="email"
        class="mt-2 block w-full rounded-lg border border-border bg-card px-3 py-2.5 text-sm text-ink placeholder:text-muted focus:border-ink/40 focus:outline-none focus:ring-2 focus:ring-accent/30"
        placeholder="jane@company.com"
      />
    </label>
  </div>

  <label class="block">
    <span class="text-sm font-medium text-ink">Company</span>
    <input
      type="text"
      name="company"
      autocomplete="organization"
      class="mt-2 block w-full rounded-lg border border-border bg-card px-3 py-2.5 text-sm text-ink placeholder:text-muted focus:border-ink/40 focus:outline-none focus:ring-2 focus:ring-accent/30"
      placeholder="Optional"
    />
  </label>

  <label class="block">
    <span class="text-sm font-medium text-ink">What are you working on?</span>
    <textarea
      name="message"
      rows="5"
      required
      class="mt-2 block w-full rounded-lg border border-border bg-card px-3 py-2.5 text-sm text-ink placeholder:text-muted focus:border-ink/40 focus:outline-none focus:ring-2 focus:ring-accent/30"
      placeholder="A few sentences on the problem, the timeline, and any platforms involved."
    ></textarea>
  </label>

  <div class="flex items-center justify-between gap-4">
    <p class="text-xs text-muted">
      We'll only use this to reply. No newsletter, no list-broking.
    </p>
    <button type="submit" class="btn btn-primary">
      Send message
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M13 6l6 6-6 6"></path>
      </svg>
    </button>
  </div>
</form>

<div id="contact-success" class="hidden rounded-lg border border-border bg-card p-6">
  <p class="font-display text-lg font-semibold text-ink">{contact.form.successTitle}</p>
  <p class="mt-2 text-sm text-muted">{contact.form.successBody}</p>
</div>

<div id="contact-error" class="hidden rounded-lg border border-accent/40 bg-accent-soft p-6">
  <p class="font-display text-lg font-semibold text-ink">{contact.form.errorTitle}</p>
  <p class="mt-2 text-sm text-muted">{contact.form.errorBody}</p>
</div>

<script is:inline>
  (function () {
    const form = document.getElementById('contact-form');
    const success = document.getElementById('contact-success');
    const error = document.getElementById('contact-error');
    if (!form) return;

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      error?.classList.add('hidden');
      const formData = new FormData(form);
      const submit = form.querySelector('button[type="submit"]');
      if (submit) {
        submit.setAttribute('disabled', 'true');
        submit.textContent = 'Sending…';
      }
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });
        const data = await res.json();
        if (data.success) {
          form.classList.add('hidden');
          success?.classList.remove('hidden');
        } else {
          throw new Error(data.message || 'Submission failed');
        }
      } catch (err) {
        if (submit) {
          submit.removeAttribute('disabled');
          submit.textContent = 'Send message';
        }
        error?.classList.remove('hidden');
      }
    });
  })();
</script>
