---
import site from '../data/site.json';

interface Props {
  eyebrow?: string;
  title?: string;
}

const { eyebrow = 'Partnerships', title = 'Building on the platforms our clients already trust.' } = Astro.props;
---

<section class="container-content py-section md:py-section-lg">
  <div class="max-w-2xl">
    <p class="eyebrow">{eyebrow}</p>
    <h2 class="mt-3 text-h2 font-display font-semibold">{title}</h2>
  </div>

  <ul class="mt-10 grid grid-cols-2 gap-px overflow-hidden rounded-lg border border-border bg-border md:grid-cols-4 lg:grid-cols-7">
    {site.partners.map((p) => (
      <li class="bg-card flex items-center justify-center px-4 py-6">
        <span class="font-display text-sm font-medium tracking-tight text-muted">{p.name}</span>
      </li>
    ))}
  </ul>

  <p class="mt-4 text-xs text-muted">
    Logos are placeholders — drop SVGs into <code class="font-mono text-[0.78em] text-ink">public/partner-logos/</code> and swap in this component when assets are available.
  </p>
</section>
