---
import site from '../data/site.json';

const products = site.products ?? [];
const intro = site.productsIntro;
---

{products.length > 0 && (
  <section class="hairline">
    <div class="container-wide py-section">
      <div class="max-w-2xl">
        <p class="eyebrow">Our products</p>
        <h2 class="mt-2 text-h2 font-display font-semibold">
          Beyond consulting - software we build, badge, and ship under the <span class="vrg-mark text-h2"><span class="vrg-v">V</span><span class="vrg-ergent">/ergent</span></span> banner.
        </h2>
        {intro && <p class="mt-3 text-sm leading-6 text-muted md:text-base md:leading-7">{intro}</p>}
      </div>

      <div class="mt-8 grid gap-3 grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
        {products.map((p) => (
          <article class="bg-card rounded-lg border border-border p-6 md:p-7 flex flex-col">
            <div class="flex items-center justify-between">
              <span class="vrg-mark text-lg">
                <span class="vrg-v">{p.markPrefix}</span><span class="vrg-ergent">{p.markSuffix}</span>
              </span>
              {p.status && (
                <span class="inline-flex items-center rounded-full border border-border bg-surface px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-muted">
                  {p.status}
                </span>
              )}
            </div>
            <h3 class="mt-3 text-base font-display font-semibold text-ink">{p.title}</h3>
            <p class="mt-1.5 text-sm leading-6 text-muted flex-1">{p.summary}</p>
            {p.url ? (
              <a
                href={p.url}
                target="_blank"
                rel="noopener"
                class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-ink hover:text-accent"
              >
                {p.linkLabel ?? 'Open'}
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 6l6 6-6 6"></path>
                </svg>
              </a>
            ) : p.linkLabel ? (
              <span class="mt-4 text-sm font-medium text-muted">{p.linkLabel}</span>
            ) : null}
          </article>
        ))}
      </div>
    </div>
  </section>
)}
