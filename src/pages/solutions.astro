---
import Base from '../layouts/Base.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import solutions from '../data/pages/solutions.json';
---

<Base title="Solutions">
  <!-- HERO -->
  <section class="container-content pt-section pb-section">
    <p class="eyebrow">{solutions.hero.eyebrow}</p>
    <h1 class="mt-6 max-w-3xl text-display font-display font-semibold leading-tight">{solutions.hero.headline}</h1>
    <p class="mt-6 max-w-2xl text-base leading-7 text-muted md:text-lg md:leading-8">{solutions.hero.subhead}</p>
  </section>

  <!-- INTRO -->
  <section class="hairline">
    <div class="container-content py-section md:py-section-lg">
      <p class="eyebrow">{solutions.intro.eyebrow}</p>
      <h2 class="mt-6 max-w-3xl font-display text-3xl font-semibold leading-snug md:text-4xl">{solutions.intro.title}</h2>
      {solutions.intro.paragraphs.map((p) => (
        <p class="mt-5 max-w-2xl text-base leading-7 text-muted md:text-lg md:leading-8">{p}</p>
      ))}
    </div>
  </section>

  <!-- SOLUTIONS LIST -->
  <section>
    <div class="container-wide py-section md:py-section-lg">
      <ul class="grid gap-10 md:grid-cols-2">
        {solutions.solutions.map((s) => (
          <li class="rounded-lg border border-border bg-card p-8 md:p-10 shadow-soft">
            <div class="flex items-start gap-5">
              <span class="shrink-0 text-accent">
                <ServiceIcon icon={s.icon} />
              </span>
              <div>
                <h3 class="font-display text-2xl font-semibold leading-snug text-ink">{s.title}</h3>
                <p class="mt-3 text-base leading-7 text-muted">{s.summary}</p>
              </div>
            </div>

            <p class="mt-6 text-base leading-7 text-ink">{s.body}</p>

            <p class="mt-8 font-mono text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">Outcomes</p>
            <ul class="mt-3 space-y-2 text-base leading-7 text-muted">
              {s.outcomes.map((o) => (
                <li class="flex gap-3">
                  <span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent" />
                  <span>{o}</span>
                </li>
              ))}
            </ul>

            {s.tooling && (
              <p class="mt-8 border-t border-border pt-5 font-mono text-[11px] font-semibold uppercase tracking-[0.18em] text-muted">
                Tooling · <span class="font-sans normal-case tracking-normal text-ink">{s.tooling}</span>
              </p>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CALLOUT -->
  <section class="hairline">
    <div class="container-content py-section md:py-section-lg">
      <p class="eyebrow">{solutions.callout.eyebrow}</p>
      <h2 class="mt-6 max-w-3xl font-display text-3xl font-semibold leading-snug md:text-4xl">{solutions.callout.title}</h2>
      <p class="mt-5 max-w-2xl text-base leading-7 text-muted md:text-lg md:leading-8">{solutions.callout.body}</p>
      <p class="mt-8">
        <a href={solutions.callout.ctaHref}
           class="inline-flex items-center gap-2 rounded-md bg-accent px-5 py-3 font-display text-sm font-semibold text-white hover:opacity-90">
          {solutions.callout.ctaLabel}
          <span aria-hidden="true">→</span>
        </a>
      </p>
    </div>
  </section>
</Base>
