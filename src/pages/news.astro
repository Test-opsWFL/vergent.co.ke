---
import Base from '../layouts/Base.astro';
import news from '../data/pages/news.json';
---

<Base title="Newsroom">
  <!-- HERO -->
  <section class="relative overflow-hidden hero-grid-bg">
    <div class="container-wide pt-section pb-section">
      <p class="eyebrow reveal-on-scroll">{news.hero.eyebrow}</p>
      <h1 class="mt-4 max-w-4xl text-display-xl font-display font-semibold reveal-on-scroll">
        {news.hero.headline}
      </h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-muted reveal-on-scroll">
        {news.hero.subhead}
      </p>
    </div>
  </section>

  <!-- STATUS -->
  <section class="hairline">
    <div class="container-wide py-section">
      <div class="max-w-2xl">
        <p class="eyebrow">{news.status.eyebrow}</p>
        <h2 class="mt-2 text-h2 font-display font-semibold">{news.status.title}</h2>
        <p class="mt-3 text-sm leading-6 text-muted md:text-base md:leading-7">{news.status.body}</p>
      </div>
    </div>
  </section>

  <!-- CATEGORIES TILE GRID -->
  <section>
    <div class="container-wide pb-section">
      <div class="grid gap-px overflow-hidden rounded-lg border border-border bg-border sm:grid-cols-2 lg:grid-cols-3">
        {news.categories.map((c) => (
          <article class="bg-card p-6 md:p-7 flex flex-col">
            <p class="eyebrow">Category</p>
            <h3 class="mt-4 text-base font-display font-semibold text-ink">{c.title}</h3>
            <p class="mt-1.5 text-sm leading-6 text-muted">{c.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PRESS CONTACT -->
  <section class="hairline">
    <div class="container-wide py-section">
      <div class="max-w-2xl">
        <p class="eyebrow">{news.press.eyebrow}</p>
        <h2 class="mt-2 text-h2 font-display font-semibold">{news.press.title}</h2>
        <p class="mt-3 text-sm leading-6 text-muted md:text-base md:leading-7">{news.press.body}</p>
        <ul class="mt-6 space-y-3 text-sm">
          <li>
            <a href={`mailto:${news.press.email}`} class="font-display text-base font-semibold text-ink hover:text-accent">
              {news.press.email}
            </a>
          </li>
          <li>
            <a href={news.press.linkedinHref} target="_blank" rel="noopener" class="font-display text-base font-semibold text-ink hover:text-accent">
              {news.press.linkedinLabel}
              <svg class="inline h-3.5 w-3.5 ml-1 -mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17 17 7M9 7h8v8"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SUBSCRIBE (honest) -->
  <section class="hairline">
    <div class="container-wide py-section">
      <div class="max-w-2xl">
        <p class="eyebrow">{news.subscribe.eyebrow}</p>
        <h2 class="mt-2 text-h2 font-display font-semibold">{news.subscribe.title}</h2>
        <p class="mt-3 text-sm leading-6 text-muted md:text-base md:leading-7">{news.subscribe.body}</p>
      </div>
    </div>
  </section>
</Base>
