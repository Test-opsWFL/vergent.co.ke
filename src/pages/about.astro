---
import Base from '../layouts/Base.astro';
import OfficeList from '../components/OfficeList.astro';
import about from '../data/pages/about.json';
---

<Base title="About">
  <!-- HERO -->
  <section class="container-content pt-section md:pt-section-lg pb-section">
    <p class="eyebrow">{about.hero.eyebrow}</p>
    <h1 class="mt-6 max-w-4xl text-display font-display font-semibold">{about.hero.headline}</h1>
    <p class="mt-6 max-w-2xl text-base leading-7 text-muted md:text-lg md:leading-8">{about.hero.subhead}</p>
  </section>

  <!-- NARRATIVE -->
  <section class="hairline">
    <div class="container-content grid gap-12 py-section md:grid-cols-[1fr,1.6fr] md:py-section-lg">
      <div>
        <p class="eyebrow">{about.narrative.eyebrow}</p>
        <h2 class="mt-3 text-h2 font-display font-semibold">{about.narrative.title}</h2>
      </div>
      <div class="space-y-5 text-base leading-7 text-muted md:text-lg md:leading-8">
        {about.narrative.paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  <!-- EXPERTISE -->
  <section class="hairline">
    <div class="container-content py-section md:py-section-lg">
      <div class="max-w-2xl">
        <p class="eyebrow">{about.expertise.eyebrow}</p>
        <h2 class="mt-3 text-h2 font-display font-semibold">{about.expertise.title}</h2>
      </div>
      <dl class="mt-12 grid gap-x-10 gap-y-10 md:grid-cols-2 lg:grid-cols-3">
        {about.expertise.items.map((it) => (
          <div class="border-t border-border pt-6">
            <dt class="font-display text-lg font-semibold text-ink">{it.title}</dt>
            <dd class="mt-3 text-sm leading-6 text-muted">{it.body}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- APPROACH -->
  <section class="hairline">
    <div class="container-content py-section md:py-section-lg">
      <div class="max-w-2xl">
        <p class="eyebrow">{about.approach.eyebrow}</p>
        <h2 class="mt-3 text-h2 font-display font-semibold">{about.approach.title}</h2>
      </div>
      <ul class="mt-10 grid gap-x-12 gap-y-3 md:grid-cols-2">
        {about.approach.bullets.map((b) => (
          <li class="flex gap-3 border-t border-border py-4 text-base text-ink">
            <span aria-hidden="true" class="mt-3 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span>
            <span>{b}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- OFFICES -->
  <section class="hairline">
    <div class="container-content py-section md:py-section-lg">
      <OfficeList />
    </div>
  </section>

  <!-- CTA -->
  <section class="hairline">
    <div class="container-content py-section md:py-section-lg">
      <div class="rounded-lg border border-border bg-card p-10 md:p-14 shadow-soft">
        <div class="grid gap-6 md:grid-cols-[1.5fr,1fr] md:items-center">
          <div>
            <h2 class="text-h2 font-display font-semibold">Working on something we can help with?</h2>
            <p class="mt-3 text-base text-muted">A short note works fine. We'll route it to the right person on our side.</p>
          </div>
          <div class="md:text-right">
            <a href="/contact" class="btn btn-primary">Talk to us</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
