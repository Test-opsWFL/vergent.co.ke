---
import Base from '../layouts/Base.astro';
import OfficeList from '../components/OfficeList.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import about from '../data/pages/about.json';
---

<Base title="About">
  <!-- HERO - title, subhead, then a verifiable highlights strip + brand mark -->
  <section class="hero-grid-bg">
    <div class="container-wide grid items-end gap-12 pt-section pb-section md:grid-cols-[1.4fr,1fr]">
      <div>
        <p class="eyebrow">{about.hero.eyebrow}</p>
        <h1 class="mt-5 max-w-3xl text-display font-display font-semibold leading-tight">
          {about.hero.headline}
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-muted">
          {about.hero.subhead}
        </p>
      </div>
      <div class="flex justify-start md:justify-end">
        <span class="h-32 md:h-40 inline-flex">
          <img
            src="/logos/vergent-logo.png"
            alt="Vergent Technology Solutions"
            class="logo-light h-32 md:h-40 w-auto object-contain opacity-95"
          />
          <img
            src="/logos/vergent-logo-dark.png"
            alt="Vergent Technology Solutions"
            class="logo-dark h-32 md:h-40 w-auto object-contain opacity-95"
          />
        </span>
      </div>
    </div>

    <!-- Highlights strip - verifiable, no fabricated metrics -->
    <div class="border-y border-border bg-card">
      <dl class="container-wide grid divide-y divide-border md:grid-cols-3 md:divide-x md:divide-y-0">
        {about.hero.highlights.map((h) => (
          <div class="px-2 py-6 md:px-8 md:py-7">
            <dt class="font-mono text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">{h.label}</dt>
            <dd class="mt-2 font-display text-2xl font-extrabold tracking-tight text-ink md:text-3xl">{h.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- PULL QUOTE - break up the wall of text -->
  <section>
    <div class="container-content py-section md:py-section-lg">
      <figure class="relative max-w-3xl mx-auto text-center">
        <span aria-hidden="true" class="absolute -top-4 left-1/2 -translate-x-1/2 font-display text-5xl leading-none text-accent/30">"</span>
        <blockquote class="font-display text-lg font-semibold leading-snug text-ink md:text-xl md:leading-tight">
          {about.pullQuote.text}
        </blockquote>
        <figcaption class="mt-5 font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-muted">
          {about.pullQuote.attribution}
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- NARRATIVE + FOOTPRINT -->
  <section class="hairline">
    <div class="container-wide grid gap-12 py-section md:grid-cols-[1fr,1.4fr] md:py-section-lg md:items-start">
      <div class="md:sticky md:top-24">
        <p class="eyebrow">{about.narrative.eyebrow}</p>
        <h2 class="mt-3 text-h2 font-display font-semibold">{about.narrative.title}</h2>
        <div class="mt-6 space-y-4 text-base leading-7 text-muted">
          {about.narrative.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <!-- Footprint - countries + roles -->
      <div>
        <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">Delivery footprint</p>
        <ol class="mt-4 grid gap-px overflow-hidden rounded-lg border border-border bg-border" role="list">
          {about.narrative.footprint.map((f, i) => (
            <li class="bg-card p-5 md:p-6">
              <div class="flex items-baseline justify-between gap-3">
                <div class="flex items-baseline gap-3">
                  <span class="font-mono text-[11px] tabular-nums text-accent">{String(i + 1).padStart(2, '0')}</span>
                  <p class="font-display text-lg font-semibold text-ink">{f.city}</p>
                  <p class="text-xs text-muted">· {f.country}</p>
                </div>
                <p class="text-right text-xs leading-snug text-muted md:text-sm">{f.role}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- EXPERTISE -->
  <section class="hairline">
    <div class="container-wide py-section">
      <div class="max-w-3xl">
        <p class="eyebrow">{about.expertise.eyebrow}</p>
        <h2 class="mt-3 text-h2 font-display font-semibold">{about.expertise.title}</h2>
        {about.expertise.intro && (
          <p class="mt-4 text-base leading-7 text-muted">{about.expertise.intro}</p>
        )}
      </div>
      <div class="mt-10 grid gap-px overflow-hidden rounded-lg border border-border bg-border md:grid-cols-2 lg:grid-cols-3">
        {about.expertise.items.map((it) => (
          <article class="bg-card p-6 md:p-7 flex flex-col">
            {it.icon && (
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent-soft text-accent">
                <ServiceIcon name={it.icon} class="h-5 w-5" />
              </span>
            )}
            <h3 class="mt-4 font-display text-base font-semibold text-ink">{it.title}</h3>
            <p class="mt-2 text-sm leading-6 text-muted">{it.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- APPROACH - numbered card grid (matches homepage rhythm) -->
  <section class="hairline">
    <div class="container-wide py-section">
      <div class="grid gap-10 md:grid-cols-[1fr,1.4fr] md:items-end">
        <div>
          <p class="eyebrow">{about.approach.eyebrow}</p>
          <h2 class="mt-3 text-h2 font-display font-semibold">{about.approach.title}</h2>
        </div>
        {about.approach.intro && (
          <p class="text-base leading-7 text-muted">{about.approach.intro}</p>
        )}
      </div>
      <ul class="mt-10 grid gap-px overflow-hidden rounded-lg border border-border bg-border md:grid-cols-2 lg:grid-cols-3">
        {about.approach.disciplines.map((d, i) => (
          <li class="bg-card p-6 md:p-7 flex flex-col">
            <div class="flex items-start gap-3">
              <span aria-hidden="true" class="mt-1 inline-flex h-6 w-6 items-center justify-center rounded-full border border-border bg-surface font-mono text-[11px] font-semibold tabular-nums text-accent">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="text-base font-display font-semibold text-ink leading-snug">{d.title}</h3>
            </div>
            <p class="mt-3 text-sm leading-6 text-muted">{d.summary}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- OFFICES -->
  <section class="hairline">
    <div class="container-wide py-section">
      <OfficeList />
    </div>
  </section>

  <!-- CTA -->
  <section class="hairline">
    <div class="container-wide py-section">
      <div class="rounded-lg border border-border bg-card p-10 md:p-14 shadow-soft">
        <div class="grid gap-6 md:grid-cols-[1.5fr,1fr] md:items-center">
          <div>
            <h2 class="text-h2 font-display font-semibold">Working on something we can help with?</h2>
            <p class="mt-3 text-base text-muted">A short note works fine. We'll route it to the right person on our side.</p>
          </div>
          <div class="md:text-right">
            <a href="/contact" class="btn btn-primary">Talk to us</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
