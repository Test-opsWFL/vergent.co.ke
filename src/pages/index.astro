---
import Base from '../layouts/Base.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import PartnerTicker from '../components/PartnerTicker.astro';
import ProductsSection from '../components/ProductsSection.astro';
import HeroWidget from '../components/HeroWidget.astro';
import StatsStrip from '../components/StatsStrip.astro';
import home from '../data/pages/home.json';
import site from '../data/site.json';
---

<Base>
  <!-- HERO - split layout, wider, with mockup widget on right -->
  <section class="relative overflow-hidden hero-grid-bg">
    <div class="container-wide grid items-center gap-10 pt-section pb-section lg:grid-cols-[minmax(0,1.1fr),minmax(0,0.9fr)]">
      <div>
        {home.hero.eyebrow && (
          <p class="eyebrow reveal-on-scroll">{home.hero.eyebrow}</p>
        )}
        <h1 class="mt-4 max-w-4xl text-display-xl font-display font-semibold reveal-on-scroll">
          {home.hero.headline}
        </h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-muted reveal-on-scroll">
          {home.hero.subhead}
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <a href={home.hero.primaryCta.href} class="btn btn-primary">
            {home.hero.primaryCta.label}
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 6l6 6-6 6"></path>
            </svg>
          </a>
          <a href={home.hero.secondaryCta.href} class="btn btn-secondary">
            {home.hero.secondaryCta.label}
          </a>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 border-t border-border pt-5 text-sm text-muted">
          <span class="text-xs uppercase tracking-[0.12em]">Offices</span>
          {site.offices.map((o) => (
            <span class="inline-flex items-center gap-2">
              <span class="text-ink">{o.city}</span>
              <span class="text-muted">{o.country}</span>
            </span>
          ))}
        </div>
      </div>

      <div class="reveal-on-scroll">
        <HeroWidget />
      </div>
    </div>
  </section>

  <!-- STATS STRIP -->
  <StatsStrip />

  <!-- POSITIONING -->
  <section>
    <div class="container-wide py-section md:py-section-lg">
      <p class="eyebrow">{home.positioning.eyebrow}</p>
      <h2 class="mt-3 max-w-4xl text-h2 font-display font-semibold leading-tight">
        {home.positioning.title}
      </h2>
      <div class="mt-6 grid gap-x-12 gap-y-3 md:grid-cols-[1fr,1.6fr]">
        <div aria-hidden="true" class="hidden md:block md:border-t md:border-border md:pt-6">
          <span class="font-display text-xs font-semibold uppercase tracking-[0.18em] text-accent">
            From strategy to production
          </span>
        </div>
        <p class="max-w-2xl text-base leading-7 text-muted">
          {home.positioning.body}
        </p>
      </div>
    </div>
  </section>

  <!-- PRODUCTS - V/ergent product family -->
  <div id="products">
    <ProductsSection />
  </div>

  <!-- SERVICES (compact) -->
  <div class="hairline">
    <ServicesGrid variant="compact" />
    <div class="container-wide -mt-6 pb-section">
      <a href="/services" class="btn btn-link inline-flex items-center gap-2">
        See full services
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </div>
  </div>

  <!-- APPROACH -->
  <section class="hairline">
    <div class="container-wide py-section md:py-section">
      <div class="grid gap-10 md:grid-cols-[1fr,1.4fr] md:items-end">
        <div>
          <p class="eyebrow">{home.approach.eyebrow}</p>
          <h2 class="mt-3 text-h2 font-display font-semibold">{home.approach.title}</h2>
        </div>
        {home.approach.body && (
          <p class="text-base leading-7 text-muted">{home.approach.body}</p>
        )}
      </div>

      <ul class="mt-10 grid gap-px overflow-hidden rounded-lg border border-border bg-border md:grid-cols-2 lg:grid-cols-3">
        {home.approach.disciplines.map((d, i) => (
          <li class="bg-card p-6 md:p-7 flex flex-col">
            <div class="flex items-start gap-3">
              <span aria-hidden="true" class="mt-1 inline-flex h-6 w-6 items-center justify-center rounded-full border border-border bg-surface font-mono text-[11px] font-semibold tabular-nums text-accent">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="text-base font-display font-semibold text-ink leading-snug">{d.title}</h3>
            </div>
            <p class="mt-3 text-sm leading-6 text-muted">{d.summary}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- PARTNERS - scrolling ticker -->
  <div class="hairline">
    <PartnerTicker />
  </div>

  <!-- CTA -->
  <section class="hairline">
    <div class="container-wide py-section md:py-section">
      <div class="rounded-lg border border-border bg-card p-10 md:p-14 shadow-soft">
        <div class="grid gap-8 md:grid-cols-[1.5fr,1fr] md:items-end">
          <div>
            <h2 class="text-h2 font-display font-semibold">{home.cta.title}</h2>
            <p class="mt-3 max-w-xl text-base text-muted">{home.cta.body}</p>
          </div>
          <div class="md:text-right">
            <a href="/contact" class="btn btn-primary">
              {home.cta.label}
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 6l6 6-6 6"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
